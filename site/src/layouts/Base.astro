---
import Nav from '../components/Nav.astro';
import footerHtml from '../fragments/_footer.html?raw';
import '../styles/global.css';

const {
  title,
  description = 'Cinebody is the video capture platform that turns your community into your content team. Direct authentic UGC at scale.',
  active,
  image = '/og.png',
  noindex = false,
} = Astro.props;

const siteName = 'Cinebody';
const fullTitle = title ? `${title} | ${siteName}` : `${siteName} | Your community is your content team`;
const canonical = new URL(Astro.url.pathname, Astro.site).href.replace(/\/$/, '') || Astro.site.href;
const ogImage = new URL(image, Astro.site).href;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Cinebody',
  legalName: 'Super 6 LLC',
  url: 'https://www.cinebody.com',
  logo: 'https://www.cinebody.com/cinebody-icon.png',
  description,
  address: { '@type': 'PostalAddress', addressLocality: 'Denver', addressRegion: 'CO', addressCountry: 'US' },
  sameAs: ['https://vimeo.com/cinebody', 'https://instagram.com/cinebody', 'https://facebook.com/cinebody'],
};
const siteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Cinebody',
  url: 'https://www.cinebody.com',
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Icons -->
    <link rel="icon" type="image/png" href="/cinebody-icon.png" />
    <link rel="apple-touch-icon" href="/cinebody-icon.png" />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Self-hosted variable font (no render-blocking third-party request) -->
    <link rel="preload" href="/fonts/inter-var.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Vimeo player domains (SDK + iframes load lazily on interaction/scroll) -->
    <link rel="preconnect" href="https://player.vimeo.com" />
    <link rel="preconnect" href="https://i.vimeocdn.com" crossorigin />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
  </head>
  <body>
    <a href="#content" class="skip-link">Skip to content</a>

    <Nav active={active} />

    <main id="content">
      <slot />
    </main>

    <Fragment set:html={footerHtml} />

    <!-- Click-to-play / autoplay video controller. The Vimeo SDK is loaded
         lazily, only when a video actually plays, so it never weighs on the
         initial load of any page. -->
    <script is:inline>
      (function () {
        var playSVG = '<svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21"/></svg>';
        var svgMuted = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 5L6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>';
        var svgUnmuted = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>';

        var isMobile = window.innerWidth < 768;
        var isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
        var activePlayer = null, activeBtn = null, sdkPromise = null;

        function loadSDK() {
          if (sdkPromise) return sdkPromise;
          sdkPromise = new Promise(function (resolve) {
            var s = document.createElement('script');
            s.src = 'https://player.vimeo.com/api/player.js';
            s.onload = resolve;
            document.head.appendChild(s);
          });
          return sdkPromise;
        }

        function loadVideo(container, videoId, hash) {
          if (container.classList.contains('playing')) return;
          var base = 'https://player.vimeo.com/video/' + videoId;
          var src = (hash ? base + '?h=' + hash + '&background=1' : base + '?background=1') + '&dnt=1';
          var iframe = document.createElement('iframe');
          iframe.src = src;
          iframe.allow = 'autoplay';
          iframe.loading = 'lazy';
          iframe.title = container.getAttribute('data-title') || 'Cinebody customer video';
          container.insertBefore(iframe, container.firstChild);
          container.classList.add('playing');
          loadSDK().then(function () {
            if (window.Vimeo && Vimeo.Player) container._player = new Vimeo.Player(iframe);
          });
        }

        document.querySelectorAll('.vid-playable').forEach(function (container) {
          var videoId = container.getAttribute('data-vimeo');
          var hash = container.getAttribute('data-vimeo-h');
          var autoplayDesktop = container.hasAttribute('data-autoplay');
          var autoplayAlways = container.hasAttribute('data-autoplay-always');
          if (!videoId) return;

          var shouldAutoplay = !isSafari && !isMobile && (autoplayAlways || autoplayDesktop);

          var playBtn = document.createElement('div');
          playBtn.className = 'vid-play-btn';
          playBtn.innerHTML = playSVG;
          container.appendChild(playBtn);
          if (shouldAutoplay) {
            playBtn.style.opacity = '0';
            playBtn.style.pointerEvents = 'none';
          }

          var muteBtn = document.createElement('button');
          muteBtn.className = 'vid-mute-btn';
          muteBtn.innerHTML = svgMuted;
          muteBtn.setAttribute('aria-label', 'Unmute');
          container.appendChild(muteBtn);

          if (shouldAutoplay) {
            var obs = new IntersectionObserver(function (entries) {
              entries.forEach(function (e) {
                if (e.isIntersecting) { loadVideo(container, videoId, hash); obs.unobserve(container); }
              });
            }, { threshold: 0.15 });
            obs.observe(container);
          }

          container.addEventListener('click', function (e) {
            if (e.target.closest('.vid-mute-btn')) return;
            loadVideo(container, videoId, hash);
            playBtn.style.opacity = '0';
            playBtn.style.pointerEvents = 'none';
          });

          muteBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            var player = container._player;
            if (!player) return;
            if (activeBtn === muteBtn) {
              player.setVolume(0); muteBtn.innerHTML = svgMuted; muteBtn.setAttribute('aria-label', 'Unmute');
              activePlayer = null; activeBtn = null; return;
            }
            if (activePlayer && activeBtn) {
              activePlayer.setVolume(0); activeBtn.innerHTML = svgMuted; activeBtn.setAttribute('aria-label', 'Unmute');
            }
            player.setVolume(1); muteBtn.innerHTML = svgUnmuted; muteBtn.setAttribute('aria-label', 'Mute');
            activePlayer = player; activeBtn = muteBtn;
          });
        });
      })();
    </script>

    <!-- Homepage hero scroller: poster thumbnails carry the visual. On mobile or
         with reduced-motion we never stream the background videos at all; on
         desktop we only stream the cards currently in view and unload them once
         they scroll out, so the page never pulls tens of MB of video up front. -->
    <script is:inline>
      (function () {
        var iframes = Array.prototype.slice.call(document.querySelectorAll('.scr-card iframe[data-src]'));
        if (!iframes.length) return;
        var noVideo =
          window.matchMedia('(max-width: 767px)').matches ||
          window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
          !('IntersectionObserver' in window);
        if (noVideo) return;
        function withDnt(u) { return u + (u.indexOf('?') > -1 ? '&' : '?') + 'dnt=1'; }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            var f = e.target;
            if (e.isIntersecting) {
              if (!f.getAttribute('src')) { f.title = 'Cinebody customer video'; f.setAttribute('src', withDnt(f.dataset.src)); }
            } else if (f.getAttribute('src')) {
              f.removeAttribute('src'); // revert to poster, stop the stream
            }
          });
        }, { threshold: 0.2 });
        var idle = window.requestIdleCallback || function (cb) { return setTimeout(cb, 300); };
        idle(function () { iframes.forEach(function (f) { io.observe(f); }); });
      })();
    </script>

    <!-- Vercel Web Analytics + Speed Insights (served by Vercel in production) -->
    <script defer src="/_vercel/insights/script.js"></script>
    <script defer src="/_vercel/speed-insights/script.js"></script>
  </body>
</html>
