---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import '../../styles/blog.css';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const fmt = (d) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<Base
  title="Blog"
  active="blog"
  description="Field notes on video, UGC, and creation from the Cinebody team: production tips, content strategy, and how brands capture authentic video at scale."
>
  <section class="blog-hero">
    <div class="blog-wrap">
      <p class="blog-eyebrow">The Cinebody Blog</p>
      <h1>Notes on video, UGC, and creation.</h1>
      <p>Production tips, content strategy, and how the best brands turn their community into a content engine.</p>
    </div>
  </section>

  <div class="blog-wrap">
    <div class="blog-grid">
      {posts.map((post) => (
        <a class="blog-card" href={`/cinebody-blog/${post.id}`}>
          {post.data.heroImage && (
            <img class="blog-card__img" src={post.data.heroImage} alt="" loading="lazy" decoding="async" />
          )}
          <div class="blog-card__body">
            <div class="blog-card__meta">{fmt(post.data.pubDate)} &middot; {post.data.author}</div>
            <h2 class="blog-card__title">{post.data.title}</h2>
            <p class="blog-card__excerpt">{post.data.description}</p>
            <span class="blog-card__more">Read more &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
