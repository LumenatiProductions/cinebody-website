---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import '../../styles/blog.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { title, description, pubDate, author, heroImage } = post.data;
const fmt = (d) => d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const CALENDLY = 'https://calendly.com/tyler-cinebody/creating-high-quality-ugc-with-cinebody';
---

<Base title={title} description={description} image={heroImage || '/og.png'}>
  <article class="post">
    <div class="post-head">
      <p class="post-meta"><span>Blog</span> &nbsp;&middot;&nbsp; {fmt(pubDate)} &nbsp;&middot;&nbsp; {author}</p>
      <h1>{title}</h1>
    </div>

    {heroImage && (
      <div class="post-hero-img"><img src={heroImage} alt={title} fetchpriority="high" /></div>
    )}

    <div class="post-content" set:html={post.body} />

    <div class="post-foot">
      <a class="post-foot__back" href="/cinebody-blog">&larr; All posts</a>
    </div>

    <div class="post-cta">
      <h2>Turn your community into your content team.</h2>
      <p>See how Cinebody captures authentic video at scale.</p>
      <a class="blog-btn" href={CALENDLY} target="_blank" rel="noopener">Book a Demo &rarr;</a>
    </div>
  </article>
</Base>
